index 597f6f72..96d2ca2a 100644
--- a/helm/dra-driver-nvidia-gpu/templates/networkpolicy-controller.yaml
+++ b/helm/dra-driver-nvidia-gpu/templates/networkpolicy-controller.yaml
@@ -11,7 +11,9 @@ spec:
     matchLabels:
       {{- include "dra-driver-nvidia-gpu.selectorLabels" (dict "context" . "componentName" "controller") | nindent 6 }}
   policyTypes:
+  - Ingress
   - Egress
+  ingress: []
   egress:
   # Some CNIs are not capable of controlling access to host network resources nor plain IP addresses,
   # as they are identity based and these resources are not being covered this way.
@@ -22,4 +24,17 @@ spec:
       port: 443
     - protocol: TCP
       port: 6443
+  # Allow DNS resolution to kube-dns.
+  - to:
+    - namespaceSelector:
+        matchLabels:
+          kubernetes.io/metadata.name: kube-system
+      podSelector:
+        matchLabels:
+          k8s-app: kube-dns
+    ports:
+    - protocol: UDP
+      port: 53
+    - protocol: TCP
+      port: 53
 {{- end }}
